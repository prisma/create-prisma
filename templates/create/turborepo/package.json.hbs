{
  "name": "{{projectName}}",
  "private": true,
  "version": "0.0.1",
  "packageManager": "{{#if (eq packageManager "bun")}}bun@1.3.9{{else}}{{#if (eq packageManager "pnpm")}}pnpm@10.16.1{{else}}npm@10.9.0{{/if}}{{/if}}",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --filter=@repo/api",
    "typecheck": "turbo run typecheck",
    "db:generate": "turbo run db:generate --filter=@repo/db",
    "db:push": "turbo run db:push --filter=@repo/db",
    "db:migrate": "turbo run db:migrate --filter=@repo/db",
    "db:seed": "turbo run db:seed --filter=@repo/db"
  },
  "devDependencies": {
    "turbo": "^2.5.6"
  }
}
