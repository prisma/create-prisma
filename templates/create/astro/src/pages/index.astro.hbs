---
{{#if (eq schemaPreset "basic")}}
import prisma from "../lib/prisma";

const formatter = new Intl.DateTimeFormat("en", {
  dateStyle: "medium",
  timeStyle: "short",
});

const users = await prisma.user
  .findMany({
    take: 10,
    orderBy: {
      createdAt: "desc",
    },
  })
  .catch(() => undefined);
{{/if}}
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
{{#if (eq schemaPreset "basic")}}
    <title>create-prisma + astro</title>
{{else}}
    <title>create-prisma + astro</title>
{{/if}}
  </head>
  <body>
    <main class="shell">
      <div class="hero">
        <p class="eyebrow">Astro + Prisma 7</p>
{{#if (eq schemaPreset "basic")}}
        <h1>Users from your database, loaded on the server.</h1>
        <p class="lede">
          This page reads from <code>src/pages/index.astro</code> using the Prisma instance in
          <code>src/lib/prisma.ts</code>. An Astro API route is also scaffolded in
          <code>src/pages/api/users.ts</code>.
        </p>
      </div>

      <section class="panel">
        <div class="panel-header">
          <h2>Seeded users</h2>
          <span>{users?.length ?? 0} total</span>
        </div>

        {!users ? (
          <p class="empty">
            Could not query users yet. Run <code>db:migrate</code>, then <code>db:seed</code>,
            then refresh.
          </p>
        ) : users.length === 0 ? (
          <p class="empty">No users yet. Run <code>db:seed</code> after your first migration.</p>
        ) : (
          <ul class="users">
            {users.map((user) => (
              <li>
                <div>
                  <strong>{user.name ?? "Unnamed user"}</strong>
                  <p>{user.email}</p>
                </div>
                <time datetime={user.createdAt.toISOString()}>
                  {formatter.format(user.createdAt)}
                </time>
              </li>
            ))}
          </ul>
        )}
      </section>
{{else}}
        <h1>Your Astro app is ready.</h1>
        <p class="lede">
          Edit <code>prisma/schema.prisma</code>, run <code>db:migrate</code>, then load your data
          in Astro pages or API routes with the Prisma instance in <code>src/lib/prisma.ts</code>.
        </p>
      </div>

      <section class="panel">
        <div class="panel-header">
          <h2>What's included</h2>
          <span>Starter kit</span>
        </div>

        <ul class="users">
          <li>
            <div>
              <strong>Prisma client</strong>
              <p>Use the shared instance from <code>src/lib/prisma.ts</code>.</p>
            </div>
          </li>
          <li>
            <div>
              <strong>API route example</strong>
              <p>See <code>src/pages/api/users.ts</code> for an Astro server endpoint.</p>
            </div>
          </li>
          <li>
            <div>
              <strong>Seed script</strong>
              <p>Run <code>db:seed</code> after your first migration.</p>
            </div>
          </li>
        </ul>
      </section>
{{/if}}
    </main>
  </body>
</html>

<style>
  :global(body) {
    margin: 0;
    font-family:
      "Instrument Sans",
      "Segoe UI",
      sans-serif;
    background: #f7f8fb;
    color: #0f172a;
  }

  .shell {
    width: min(64rem, 100%);
    margin: 0 auto;
    padding: 4rem 1.5rem 5rem;
  }

  .hero {
    margin-bottom: 2rem;
  }

  .eyebrow {
    margin: 0 0 0.75rem;
    color: #10b981;
    font-size: 0.875rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  h1 {
    margin: 0;
    max-width: 12ch;
    font-size: clamp(2.75rem, 7vw, 5rem);
    line-height: 0.95;
  }

  .lede {
    max-width: 42rem;
    font-size: 1.05rem;
    line-height: 1.7;
    color: #475569;
  }

  .panel {
    padding: 1.5rem;
    border: 1px solid #dbe2ea;
    border-radius: 1.5rem;
    background: #ffffff;
    box-shadow: 0 12px 32px rgba(15, 23, 42, 0.06);
  }

  .panel-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  h2 {
    margin: 0;
    font-size: 1.125rem;
  }

  .panel-header span,
  .empty,
  time,
  p {
    color: #64748b;
  }

  .users {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.75rem;
  }

  .users li {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1rem 1.125rem;
    border-radius: 1rem;
    background: #f8fafc;
    border: 1px solid #dbe2ea;
  }

  .users p {
    margin: 0.2rem 0 0;
  }

  time {
    font-size: 0.875rem;
    white-space: nowrap;
  }

  code {
    padding: 0.15rem 0.4rem;
    border-radius: 0.35rem;
    background: #eef2f7;
    font-family:
      SFMono-Regular,
      Consolas,
      monospace;
    font-size: 0.95em;
  }

  @media (max-width: 640px) {
    .shell {
      padding-top: 3rem;
    }

    .users li,
    .panel-header {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
